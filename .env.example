# ── OpenRouter (cloud) ────────────────────────────────────────────────────────
# Get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
QWEN_MODEL=qwen/qwen-2.5-coder-32b-instruct

# ── RAG / Web search (optional) ───────────────────────────────────────────────
# Enables the web_search tool. Free tier: 1,000 searches/month.
# Get a key at https://tavily.com
# TAVILY_API_KEY=tvly-...

# ── Local model via Ollama ─────────────────────────────────────────────────────
# 1. Install Ollama: https://ollama.com
# 2. Pull the model: ollama pull qwen2.5-coder:32b   (or :14b / :7b / :3b)
# 3. Uncomment the lines below and comment out the OpenRouter lines above
#
# QQ_BASE_URL=http://localhost:11434/v1
# QWEN_MODEL=qwen2.5-coder:32b
# (no API key needed for Ollama)

# ── Local model via LM Studio ─────────────────────────────────────────────────
# 1. Install LM Studio: https://lmstudio.ai
# 2. Download a Qwen2.5-coder GGUF model inside LM Studio
# 3. Start the local server in LM Studio (default port 1234)
# 4. Uncomment the lines below
#
# QQ_BASE_URL=http://localhost:1234/v1
# QQ_API_KEY=lm-studio
# QWEN_MODEL=qwen2.5-coder-32b-instruct   (match whatever you loaded)
