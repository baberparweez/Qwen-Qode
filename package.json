{
  "name": "qwen-qode",
  "version": "0.1.0",
  "description": "A local coding agent powered by Qwen2.5-coder via OpenRouter",
  "main": "dist/index.js",
  "bin": {
    "qq": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "web:server": "node dist/index.js --web",
    "web:ui": "npm run dev --prefix web",
    "web": "concurrently \"npm run web:server\" \"npm run web:ui\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@xenova/transformers": "^2.17.2",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "concurrently": "^9.0.0",
    "dotenv": "^16.4.5",
    "glob": "^11.0.0",
    "openai": "^4.67.0",
    "ora": "^8.1.1",
    "readline": "^1.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.4",
    "vitest": "^4.1.7"
  },
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  }
}
